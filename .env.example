# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.

# FullCalendar license key.
# Use "GPL-My-Project-Is-Open-Source" for open-source projects,
# or your purchased commercial key for private/commercial use.
VITE_FULLCALENDAR_LICENSE=GPL-My-Project-Is-Open-Source

# Google Maps — powers the live fleet map on the dashboard.
# Create a key in Google Cloud Console, enable "Maps JavaScript API",
# and restrict it by HTTP referrer (ops.bcatcorp.com, localhost:5173).
VITE_GOOGLE_MAPS_API_KEY=
# Optional: a cloud-styled Map ID for Advanced Markers. Defaults to DEMO_MAP_ID.
VITE_GOOGLE_MAPS_MAP_ID=
